{
  "framework": "nextjs",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/products/lucid-horizon-workshop", "destination": "/products/lucid-horizon-workshop.html" },
    { "source": "/products/known-productions-workshop", "destination": "/products/known-productions-workshop.html" },
    { "source": "/products/jt-visuals-workshop", "destination": "/products/jt-visuals-workshop.html" },
    { "source": "/products/instagram-masterclass", "destination": "/products/instagram-masterclass.html" },
    { "source": "/products/910-admin-assistant", "destination": "/products/910-admin-assistant.html" },
    { "source": "/products/3d-made-easy", "destination": "/products/3d-made-easy.html" },
    { "source": "/products/910-sales-system", "destination": "/products/910-sales-system.html" },
    { "source": "/products", "destination": "/products.html" },
    { "source": "/products/:slug", "destination": "/maintenance" }
  ],
  "redirects": [
    { "source": "/affiliate-links", "destination": "/gear", "permanent": true },
    { "source": "/skool", "destination": "/", "permanent": true },
    { "source": "/products/build-your-instagram", "destination": "/products/instagram-masterclass", "permanent": true },
    { "source": "/iceman", "destination": "/the-6ix", "permanent": true },
    { "source": "/iceman.html", "destination": "/the-6ix", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)\\.(jpg|jpeg|png|webp|avif|svg|ico|woff2|mp4|webm|mp3|m4a|ogg)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ],
  "crons": [
    { "path": "/api/aoc/reconcile", "schedule": "*/2 * * * *" }
  ]
}
