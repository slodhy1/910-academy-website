{
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/products/lucid-horizon-workshop", "destination": "/products/lucid-horizon-workshop.html" },
    { "source": "/products", "destination": "/maintenance" },
    { "source": "/products/:slug", "destination": "/maintenance" },
    { "source": "/account", "destination": "/maintenance" },
    { "source": "/account/:path*", "destination": "/maintenance" }
  ],
  "redirects": [
    { "source": "/affiliate-links", "destination": "/gear", "permanent": true },
    { "source": "/skool", "destination": "/", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)\\.(jpg|jpeg|png|webp|avif|svg|ico|woff2)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
